{
    "name": "rublex/laravel-core-gateway",
    "description": "Vendor-agnostic core contracts and data objects for payment gateway integrations",
    "version": "1.0.0",
    "type": "library",
    "keywords": [
        "rublex",
        "core",
        "payment",
        "gateway",
        "laravel"
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Rublex\\CoreGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rublex\\CoreGateway\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
